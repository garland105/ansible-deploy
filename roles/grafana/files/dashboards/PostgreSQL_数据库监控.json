{
  "schemaVersion": 39,
  "version": 1,
  "title": "PostgreSQL 数据库监控",
  "uid": "mom-postgresql",
  "tags": [
    "mom",
    "postgresql",
    "database"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "title": "PG 实例状态",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "value": "1",
              "text": "正常"
            },
            {
              "type": "value",
              "value": "0",
              "text": "不可达"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "title": "PG 运行时间",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "pg_postmaster_start_time_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "是否在恢复模式 (Replica)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "pg_is_in_recovery_result",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "value": "1",
              "text": "Replica"
            },
            {
              "type": "value",
              "value": "0",
              "text": "Leader"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      }
    },
    {
      "title": "活跃连接数",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      }
    },
    {
      "title": "数据库连接数趋势",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{datname}} - {{state}}"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max Connections"
        }
      ]
    },
    {
      "title": "每秒事务数 (TPS)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m])",
          "legendFormat": "{{datname}}"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[1m])",
          "legendFormat": "{{datname}} - Rollback"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "流复制状态",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "pg_stat_replication_flush_lag_bytes",
          "legendFormat": "",
          "format": "table",
          "instant": true
        },
        {
          "expr": "pg_stat_replication_replay_lag_bytes",
          "legendFormat": "",
          "format": "table",
          "instant": true
        },
        {
          "expr": "pg_replication_slots_active",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "流复制延迟 (字节)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "pg_stat_replication_flush_lag_bytes",
          "legendFormat": "Flush Lag"
        },
        {
          "expr": "pg_stat_replication_replay_lag_bytes",
          "legendFormat": "Replay Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "数据库大小",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{datname}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "缓冲区命中率",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_blks_hit[5m]) / (rate(pg_stat_database_blks_hit[5m]) + rate(pg_stat_database_blks_read[5m])) * 100",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 98
              }
            ]
          }
        }
      }
    },
    {
      "title": "死锁数量",
      "type": "timeseries",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks[5m])",
          "legendFormat": "{{datname}}"
        }
      ]
    }
  ]
}